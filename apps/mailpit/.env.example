# Maximum number of messages to store (oldest are deleted when exceeded)
MP_MAX_MESSAGES=5000

# Path to SQLite database for persistence (comment out to disable persistence)
MP_DATABASE=/data/mailpit.db

# Accept any SMTP credentials without validation (useful for dev/testing)
MP_SMTP_AUTH_ACCEPT_ANY=1

# Allow SMTP auth over unencrypted connections
MP_SMTP_AUTH_ALLOW_INSECURE=1

# Optional: UI basic auth file (htpasswd format) — recommended if exposed publicly
# MP_UI_AUTH_FILE=/data/authfile

# Optional: webroot if serving under a subpath
# MP_WEBROOT=/mailpit/
